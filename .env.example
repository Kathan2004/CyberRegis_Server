# API Keys - Copy this file to .env and fill in your actual keys
SAFE_BROWSING_KEY=your_google_safe_browsing_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
GEMINI_API_KEY=your_gemini_api_key_here
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Server Configuration
FLASK_ENV=development
FLASK_DEBUG=True
PORT=4000

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://yourdomain.com

# Rate Limiting
RATE_LIMIT_PER_DAY=100
RATE_LIMIT_PER_MINUTE=10

# Cache Configuration
CACHE_MAX_SIZE=1000
CACHE_TTL=3600

# Logging
LOG_FILE=security_checker.log
LOG_LEVEL=INFO
